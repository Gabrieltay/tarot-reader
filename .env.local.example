# Google Gemini API key used by /app/api/interpret/route.ts
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model (defaults to gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Optional: overrides the canonical site URL used for social share metadata
# (defaults to https://tarot-reader-wheat.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://tarot-reader-wheat.vercel.app
