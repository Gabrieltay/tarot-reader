# Google Gemini API key used by /app/api/interpret/route.ts
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model (defaults to gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Optional: overrides the canonical site URL used for social share metadata
# (defaults to https://tarot-reader-wheat.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://tarot-reader-wheat.vercel.app

# Optional: Telegram bot used to notify a group chat when a reading is submitted
# Create a bot via https://t.me/BotFather to get a token, then add it to your
# group chat and get the chat ID (e.g. via https://api.telegram.org/bot<token>/getUpdates)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here
